# ── Core ────────────────────────────────────────────────────────────────
# Default is SQLite for zero-setup local dev (bare `uvicorn`). For production,
# comment the SQLite line and use the Postgres URL below (the Docker stack sets
# this automatically). Run `alembic upgrade head` once before first start.
DATABASE_URL=sqlite:///./smap.db
# DATABASE_URL=postgresql+psycopg://smap:smap@localhost:5432/smap

# Secret for signing dashboard session cookies (any long random string).
SESSION_SECRET=change-me-to-a-long-random-string

# Fernet key for encrypting platform OAuth tokens at rest.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Public base URL of this app (used to build OAuth redirect URIs). No trailing slash.
APP_BASE_URL=http://localhost:8000

# Extra browser origins allowed to call the API with credentials (comma-separated).
# Normally unnecessary: the Vite dev server proxies /api to this app, and in
# production the SPA is served same-origin. Only set this if you host the React
# dev server on a different origin. e.g. http://localhost:5173
# CORS_ORIGINS=

# Timezone used to render times in the dashboard (DB always stores UTC).
DISPLAY_TIMEZONE=UTC

# First admin user created on startup if no users exist.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ── AI providers (set at least one; unset providers are hidden in the UI) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Default model id shown pre-selected in the compose UI.
DEFAULT_AI_MODEL=claude-opus-4-8

# ── Facebook / Threads (Meta app) ─────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
FACEBOOK_GRAPH_VERSION=v25.0
# Comma-separated scopes requested during Facebook login.
FACEBOOK_SCOPES=pages_show_list,pages_manage_posts,pages_read_engagement,business_management
THREADS_SCOPES=threads_basic,threads_content_publish

# ── LinkedIn ──────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Posts API version header, format YYYYMM.
LINKEDIN_API_VERSION=202505
LINKEDIN_SCOPES=w_member_social,r_liteprofile

# ── Scheduler ───────────────────────────────────────────────────────────
SCHEDULER_POLL_SECONDS=60
MAX_PUBLISH_ATTEMPTS=5

# ── Media storage ─────────────────────────────────────────────────────────
# Leave S3_BUCKET empty for the local-disk fallback (files served at
# {APP_BASE_URL}/media — fine for dev). For production, set a bucket so uploads
# go to S3; the platforms fetch media by its public URL, so it must be reachable.
# S3_BUCKET=my-social-media-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=            # set for S3-compatible stores (Cloudflare R2 / MinIO / Spaces)
# S3_PUBLIC_BASE_URL=         # CDN/public base; else derived from bucket + region
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
MEDIA_MAX_IMAGE_MB=10
MEDIA_MAX_VIDEO_MB=200
